{
    "compilerOptions": {
        "target": "esnext",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "jsx": "react",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "types": ["bun", "chrome", "react", "react-dom"],
        "paths": {
            "$assets/*": ["./assets/*"],
            "$core/*": ["./src/content/core/*"],
            "$content/*": ["./src/content/*"],
            "$bg/*": ["./src/background/*"],
            "$types/*": ["./src/types/*"],
            "$shared*": ["./src/shared"],
            "$shared/*": ["./src/shared/*"]
        },
        "verbatimModuleSyntax": true,
        "noEmit": true
    },
    "include": [
        "./scripts/**/*.*",
        "./src/**/*.*",
        "main.d.ts",
        "./extension/scripts/*.ts"
    ]
}